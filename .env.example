# ─────────────────────────────────────────────────────────
# OSINT Graph Generator — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ─── Neo4j Database ───────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=osintgraph2024

# ─── HaveIBeenPwned (Optional) ────────────────────────────
# Get your key at: https://haveibeenpwned.com/API/Key
# If left empty, the system will use emailrep.io as a free fallback
HIBP_API_KEY=

# ─── Collector Settings ───────────────────────────────────
# Timeout in seconds for each HTTP request
REQUEST_TIMEOUT=15.0

# Delay between username checks (seconds) — avoids rate limiting
USERNAME_CHECK_DELAY=0.15

# Max concurrent username checks
USERNAME_CONCURRENCY=20

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Groq API Key ─────────────────────────────────────────
GROQ_API_KEY=
